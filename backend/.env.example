# Copy to .env and adjust as needed.

# PostgreSQL connection
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=assetvault

# CORS — allowed frontend origins (comma-separated)
CORS_ORIGINS=http://localhost:5173

# Storage — where uploaded files & generated thumbnails live (relative to backend/)
STORAGE_DIR=storage
# Max upload size in bytes (default 50 MiB)
MAX_UPLOAD_BYTES=52428800

# Auth (used from Phase 2 onward)
# Use a random string of at least 32 bytes, e.g. `openssl rand -hex 32`.
JWT_SECRET=dev-secret-change-me-in-production-min-32-bytes
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Google Sign-In — paste your OAuth 2.0 Client ID here to enable "Sign in with
# Google". Leave blank to disable it. See README "Google Sign-In setup".
# It looks like: 1234567890-abc123.apps.googleusercontent.com
GOOGLE_CLIENT_ID=
